   "source": [
    "text = \"Natural Language Processing is interesting\"\n",
    "tokens = []\n",
    "word = \"\"\n",
    "for ch in text:\n",
    "    if ch != \" \":\n",
    "        word += ch\n",
    "    else:\n",
    "        tokens.append(word)\n",
    "        word = \"\"\n",
    "tokens.append(word)\n",
    "\n",
    "print(\"Original Text:\", text)\n",
    "print(\"Tokens:\", tokens)"
